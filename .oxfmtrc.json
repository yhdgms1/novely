{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 115,
	"jsxSingleQuote": false,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"semi": true,
	"arrowParens": "always",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"singleQuote": true,
	"jsxBracketSameLine": false,
	"ignorePatterns": []
}
