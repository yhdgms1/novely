{
	"name": "@novely/live2d",
	"description": "Integration of live2d for novely",
	"version": "0.4.0",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		},
		"./*": "./dist/*",
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "tsdown --watch --dts",
		"build": "tsdown --dts"
	},
	"dependencies": {
		"@novely/core": "workspace:*",
		"easy-cl2d": "^0.3.1",
		"es-toolkit": "^1.39.5"
	},
	"devDependencies": {
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"@novely/core": "*"
	},
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/yhdgms1/novely/issues"
	},
	"homepage": "https://github.com/yhdgms1/novely/tree/main/packages/live2d",
	"keywords": [],
	"author": {
		"name": "Artemiy Schukin",
		"url": "https://github.com/yhdgms1"
	},
	"contributors": [],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yhdgms1/novely.git"
	},
	"files": [
		"dist/*"
	]
