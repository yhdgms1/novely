{
	"name": "@novely/core",
	"description": "Novely - powerful visual novel engine for creating interactive stories and games with branching narratives and rich multimedia content",
	"version": "0.55.0",
	"type": "module",
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"types": "./dist/index.d.mts",
	"cdn": "./dist/index.mjs",
	"unpkg": "./dist/index.mjs",
	"jsdelivr": "./dist/index.mjs",
	"browser": "./dist/index.mjs",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./*": "./dist/*",
		"./package.json": "./package.json"
	},
	"scripts": {
		"dev": "tsdown --dts --watch",
		"build": "tsdown --dts"
	},
	"devDependencies": {
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"dequal": "^2.0.3",
		"es-toolkit": "^1.39.5",
		"esm-env": "^1.2.2",
		"klona": "^2.0.6",
		"p-limit": "^6.2.0"
	},
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/yhdgms1/novely/issues"
	},
	"homepage": "https://github.com/yhdgms1/novely/tree/main/packages/core",
	"keywords": [
		"novely",
		"novel",
		"engine",
		"renpy"
	],
	"author": {
		"name": "Artemiy Schukin",
		"url": "https://github.com/yhdgms1"
	},
	"contributors": [],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yhdgms1/novely.git"
	},
	"files": [
		"dist/*"
	]
}
