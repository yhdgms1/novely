{
	"name": "@novely/particles",
	"version": "0.11.0",
	"description": "Particles Action",
	"keywords": [
		"novely",
		"particles",
		"ts-particles"
	],
	"homepage": "https://github.com/yhdgms1/novely/tree/main/packages/particles",
	"bugs": {
		"url": "https://github.com/yhdgms1/novely/issues"
	},
	"license": "ISC",
	"author": {
		"name": "Artemiy Schukin",
		"url": "https://github.com/yhdgms1"
	},
	"contributors": [],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yhdgms1/novely.git"
	},
	"files": [
		"dist/*"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/lazy.d.mts",
			"import": "./dist/lazy.mjs",
			"default": "./dist/lazy.mjs"
		},
		"./eager": {
			"types": "./dist/eager.d.mts",
			"import": "./dist/eager.mjs",
			"default": "./dist/eager.mjs"
		},
		"./*": "./dist/*",
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "tsdown --watch --dts",
		"build": "tsdown --dts"
	},
	"dependencies": {
		"@novely/core": "workspace:^",
		"@tsparticles/engine": "~3.8.1",
		"@tsparticles/slim": "~3.8.1"
	},
	"devDependencies": {
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"@novely/core": "*"
	}
}
