{
	"name": "@novely/flex-storage",
	"version": "0.3.0",
	"description": "Storage for @novely/core",
	"keywords": [
		"novely",
		"storage"
	],
	"homepage": "https://github.com/yhdgms1/novely/tree/main/packages/flex-storage",
	"bugs": {
		"url": "https://github.com/yhdgms1/novely/issues"
	},
	"license": "ISC",
	"author": {
		"name": "Artemiy Schukin",
		"url": "https://github.com/yhdgms1"
	},
	"contributors": [],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yhdgms1/novely.git"
	},
	"files": [
		"dist/*"
	],
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.mts",
