		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "tsdown --dts --watch",
		"build": "tsdown --dts"
	},
	"dependencies": {
		"@novely/core": "workspace:*",
		"lz-string": "^1.5.0",
		"seroval": "^1.3.2"
	},
	"devDependencies": {
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"@novely/core": "*"
	}
}
